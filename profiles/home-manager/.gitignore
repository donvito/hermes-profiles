# Per-profile ignore rules — keep secrets and runtime state out of the repo.
# Mirrors the installer's hard-excluded paths (USER_OWNED_EXCLUDE in
# hermes_cli/profile_distribution.py) so a profile developed in place can
# never leak user data into the distribution.

# Credentials & secrets — NEVER commit
auth.json
.env
.env.EXAMPLE

# Runtime databases & state
state.db
state.db-shm
state.db-wal
hermes_state.db
response_store.db
response_store.db-shm
response_store.db-wal
gateway.pid
gateway_state.json
processes.json
auth.lock
active_profile
.update_check
errors.log
.hermes_history

# User data — NEVER commit
memories/
sessions/
logs/
plans/
workspace/
home/

# Caches & generated artifacts
image_cache/
audio_cache/
document_cache/
browser_screenshots/
cache/
checkpoints/
sandboxes/
backups/

# Infrastructure
hermes-agent/
.worktrees/
profiles/
bin/
node_modules/

# User customization namespace
local/

# Runtime cron store (jobs are registered per-machine, not shipped)
cron/jobs.json
cron/output/
cron/ticker_heartbeat
cron/ticker_last_success
